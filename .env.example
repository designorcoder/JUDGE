# JudgeHub Environment Variables (Node.js version)

PORT=3000
JWT_SECRET=supersecretjwtsecretkeychangeinproduction

# Database Configuration
# Leave blank to use local SQLite (database.sqlite) out of the box:
# DATABASE_URL=

# For PostgreSQL (production, e.g. Neon or Render):
# DATABASE_URL=postgres://db_user:db_password@localhost:5432/judgehub_db
